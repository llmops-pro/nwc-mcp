# Copy this file to .env and fill in your values. .env is gitignored.
# Env vars passed by the parent process (Claude Code, Claude Desktop, etc.)
# take precedence over the values here.

# Required ----------------------------------------------------------------

# Your NWC connection string from Alby Hub (Sub-wallets → Connections) or any
# NIP-47-compatible wallet. Treat as a SECRET — anyone holding this can spend
# up to the daily cap.
NWC_CONNECTION_STRING=nostr+walletconnect://paste-yours-here

# Rolling 24h spend cap, in sats. The server refuses to start without this.
NWC_DAILY_BUDGET_SATS=10000

# Optional ----------------------------------------------------------------

# Lifetime spend cap. Leave unset for no cap.
# NWC_TOTAL_BUDGET_SATS=100000

# Per-payment cap (applied to every spend tool individually).
# NWC_MAX_INVOICE_SATS=5000

# Disable all spend tools — only read/receive tools work. Useful for dev,
# eval runs, and curious-but-not-trusting first-time setup.
# NWC_READ_ONLY=false

# Two-step confirmation. When true, spend tools return a 16-byte hex token
# (5-min TTL) instead of executing; agent must call nwc_confirm_payment to
# actually run the payment. Trades agent autonomy for safety.
# NWC_REQUIRE_CONFIRM=false

# Opt-in for nwc_pay_keysend. Off by default — keysend has no payment-hash
# receipt and a weaker safety surface than bolt11.
# NWC_KEYSEND_ENABLED=false

# Allowlist of payment destinations. When non-empty, ONLY these are payable.
# Match strings: LN addresses (alice@getalby.com), payee pubkeys (bolt11),
# raw LNURLs (lnurl1...), or keysend pubkeys.
# NWC_ALLOWED_DESTINATIONS=alice@getalby.com,bob@walletofsatoshi.com

# Audit log file (one JSON line per tool call, append-only).
# NWC_LOG_PATH=./nwc-mcp.log

# Persisted budget tracker state.
# NWC_BUDGET_STATE_PATH=./nwc-mcp-state.json
